NODE1_REDIS_HOST={{ node1_ip }}
NODE1_REDIS_PORT=6379
NODE1_REDIS_DB=0
NODE1_REDIS_PASSWD={{ redis_password }}
NODE2_REDIS_HOST=127.0.0.1
NODE2_REDIS_PORT=6379
NODE2_REDIS_DB=0
NODE2_REDIS_PASSWD={{ redis_password }}


WORKER_LOG_FILE=/var/log/mini-orch/worker.log
QUEUE_STREAM_KEY=jobs:stream
QUEUE_GROUP=mini-orch-workers
QUEUE_CONSUMER=node2
QUEUE_BATCH_SIZE=10
QUEUE_BLOCK_MS=5000
STATUS_STREAM_KEY=jobs:status
STATUS_FAILED_KEY=jobs:status:failed
STATUS_RETRY_INTERVAL_MS=10000
FALLBACK_FILE=/var/log/mini-orch/fallback.jsonl
